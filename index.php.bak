$htmlDocHead->saveConfig(); // Save the updated counts back to the file
$config = $htmlDocHead;

// Generate URL list items
$url_listitem = '<ol>';
foreach ($htmlDocHead->config['home_urls'] as $entry) {
    $url = $entry['url'];
    $name = $entry['name'];
    $count = $entry['count'];

    // Update count for this URL (optional if you want to count display times)
    // $htmlDocHead->updateUrlCount($url);

    $url_listitem .= '<li class="float-left p-2">';
    $url_listitem .= '<a href="' . $url . '" target="_blank">' . $name . '</a> ';
    $url_listitem .= '(Accessed ' . $count . ' times)';
    $url_listitem .= '</li>';
}
$url_listitem .= '</ol>';

