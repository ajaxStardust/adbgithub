<?php
namespace Bbadb;
use Bbadb\public\class\Backlinks as Backlinks;
use Bbadb\public\class\HtmlDocHead as HtmlDocHead;
use Bbadb\public\class\Nav as Nav;
define('ADBLOCTN', __DIR__);

function namespaceAutoload($rawClass)
{
    $class = str_replace('\\', DIRECTORY_SEPARATOR, $rawClass);

    $possiblePaths[] = 'file.php';
    $possiblePaths[] = 'class-file.php';
    $possiblePaths[] = '..\sys\class\class.file.inc.php';

    foreach ($possiblePaths as $templatePath) {
        $path = str_replace(["\\", "file"], [DIRECTORY_SEPARATOR, $class], $templatePath);
        $path = str_replace(__NAMESPACE__.'/', '', $path);
        $path = strtolower($path);

        if (file_exists($path)) {
            include_once "$path";
            break;
        }
    }
}

spl_autoload_register(__NAMESPACE__."\\namespaceAutoload"); 

// require 'public/class/class-html-dochead.php';

$backlinksHtml = new Backlinks;
$htmlDocHead = new HtmlDocHead(ADBLOCTN);
$navClass = new Nav;

 

